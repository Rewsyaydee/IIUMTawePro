# Client-safe Vite variables
VITE_APP_MODE=mock
VITE_ENABLE_MOCKS=true
VITE_API_AUTH_BRIDGE=false
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# If Supabase shows "publishable key", paste it into VITE_SUPABASE_ANON_KEY for the browser.
VITE_API_BASE_URL=
VITE_TELEGRAM_BOT_USERNAME=

# Server-only secrets. Never prefix these with VITE_.
SUPABASE_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEB_APP_URL=
TELEGRAM_WEBHOOK_SECRET=
WELLBEING_SUPPORT_URL=
COMMITTEE_TELEGRAM_IDS=
COMMITTEE_BUREAU_BY_TELEGRAM_ID=
DEFAULT_COMMITTEE_BUREAU=
SUPABASE_SERVICE_ROLE_KEY=
# If Supabase shows "secret key", use it as a server-only key. Do not expose it to the browser.
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=
SUPABASE_JWT_SECRET=
COMMITTEE_ACCESS_CODES=
HEAD_ACCESS_CODES=
MAINBOARD_ACCESS_CODES=
